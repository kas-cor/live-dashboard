# ============================================
# Dashboard Environment Configuration
# ============================================
# COPY this file to .env (NOT in git), set your real values.
# ALL sensitive data here — NEVER commit to version control.

# ============================================
# Server SSH Monitoring (JSON)               |
# ============================================
# Add remote servers to monitor via SSH.      |
# Format: {"serverId": {"name":"DisplayName","host":"IP","port":22,"user":"root"}}  |
# Leave empty {} or omit to disable.          |
# SERVERS_CONFIG={}

# ============================================
# Alert Webhook                                |
# ============================================
# URL to POST alerts to when warning triggers |
# Token sent as Authorization: Bearer <token> |
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_AUTH_TOKEN=

# ============================================
# Host-specific Settings                       |
# ============================================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=9090
BACKEND_HOSTNAME=claw
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3003

# ============================================
# Docker Volume Mounts                         |
# ============================================
HOST_PROC=/host/proc
HOST_SYS=/host/sys
HOST_JOURNAL=/var/log/journal
TODO_PATH=/host/todo/tasks.json
TS_SOCKET=/var/run/tailscale/tailscaled.sock

# ============================================
# Tailscale                                    |
# ============================================
TAILSCALE_SELF_IP=

# ============================================
# Weather API (Open-Meteo)                     |
# ============================================
WEATHER_LAT=55.7558
WEATHER_LON=37.6173
WEATHER_CITY=Moscow
WEATHER_API=https://api.open-meteo.com/v1/forecast

# ============================================
# External APIs                                |
# ============================================
CRYPTO_API=https://api.coingecko.com/api/v3/simple/price
